    filter cftcTrade.IsAllowableActionForCFTC
    then extract commondtcc.DTCC_OtherPaymentPayerIDType

reporting rule DTCC_OtherPaymentReceiverIDType from TransactionReportInstruction: <"Other Payment Receiver ID Type">
    filter cftcTrade.IsAllowableActionForCFTC
    then extract commondtcc.DTCC_OtherPaymentReceiverIDType

reporting rule DTCC_ChangeInNotionalAmount1 from TransactionReportInstruction: <"Change in Notional Amount 1">
    extract ChangeInNotionalAmountLeg1(item, 99999999999999999999.99999)

reporting rule DTCC_ChangeInNotionalAmount2 from TransactionReportInstruction: <"Change in Notional Amount 2">
    extract ChangeInNotionalAmountLeg2(item, 99999999999999999999.99999)

reporting rule DTCC_LargeNotionalOffFacilitySwapElectionIndicator from TransactionReportInstruction: <"Large Notional Off-Facility Swap Election Indicator">
    filter cftcTrade.IsAllowableActionForCFTC
    then extract reportableInformation
    then filter
        partyInformation -> regimeInformation -> supervisoryBody any = SupervisoryBodyEnum -> CFTC
    then extract
        if executionVenueType <> SEF and executionVenueType <> DCM
        then largeSizeTrade

reporting rule DTCC_MandatoryClearingIndicator from TransactionReportInstruction: <"Mandatory Clearing Indicator">
    filter cftcTrade.IsAllowableActionForCFTC
    then extract reportableInformation -> partyInformation -> regimeInformation
    then filter supervisoryBody = SupervisoryBodyEnum -> CFTC
    then extract
        if mandatorilyClearable = MandatorilyClearableEnum -> ProductAndCptyMandatory
        then True
        else if mandatorilyClearable = MandatorilyClearableEnum -> ProductMandatoryButNotCpty
        then False
    then distinct only-element

reporting rule DTCC_OriginalSwapSDRIDType from TransactionReportInstruction: <"Original Swap SDR - ID Type">
    filter cftcTrade.IsAllowableActionForCFTC
    then extract
        if common.link.OriginalSwapSDRIdentifier exists
        then PartyIdentifierTypeEnum -> LEI

reporting rule DTCC_PhysicalCommodityContractIndicator from TransactionReportInstruction: <"Physical Commodity Contract Indicator">
    filter cftcTrade.IsAllowableActionForCFTC
    then extract reportInstruction [
        reportInstruction -> reportableInformation -> partyInformation
            filter partyReference = reportInstruction -> reportingSide -> reportingParty
            then only-element
            then extract
                if regimeInformation -> cftcPartyInformation -> physicalCommodityContractIndicator exists
                then regimeInformation -> cftcPartyInformation -> physicalCommodityContractIndicator only-element
                else False
    ]

reporting rule DTCC_SDMSPIndicatorCounterparty1 from TransactionReportInstruction: <"SD MSP Indicator - Counterparty 1">
    filter cftcTrade.IsAllowableActionForCFTC
    then extract reportInstruction [
        reportInstruction -> reportableInformation -> partyInformation
            filter partyReference = reportInstruction -> reportingSide -> reportingParty
            then filter regimeInformation -> cftcPartyInformation -> organizationType exists
            then extract regimeInformation
            then flatten
            then filter supervisoryBody = SupervisoryBodyEnum -> CFTC
            then only-element
            then extract
                if (cftcPartyInformation -> organizationType = CFTCEntityClassificationEnum -> SD
                        or cftcPartyInformation -> organizationType = CFTCEntityClassificationEnum -> MSP)
                then True
                else False
    ]

reporting rule DTCC_SDMSPIndicatorCounterparty2 from TransactionReportInstruction: <"SD MSP Indicator - Counterparty 2">
    filter cftcTrade.IsAllowableActionForCFTC
    then extract reportInstruction [
        reportInstruction -> reportableInformation -> partyInformation
            filter
                partyReference = reportInstruction -> reportingSide -> reportingCounterparty
            then filter regimeInformation -> cftcPartyInformation -> organizationType exists
            then extract regimeInformation
            then flatten
            then filter supervisoryBody = SupervisoryBodyEnum -> CFTC
            then only-element
            then extract
                if cftcPartyInformation -> organizationType = CFTCEntityClassificationEnum -> SD
                        or cftcPartyInformation -> organizationType = CFTCEntityClassificationEnum -> MSP
                then True
                else False
    ]

reporting rule DTCC_SEFOrDCMAnonymousExecutionIndicator from TransactionReportInstruction: <"SEF or DCM Anonymous Execution Indicator">
    filter cftcTrade.IsAllowableActionForCFTC
    then if (cde.event.ActionType = TERM
                and [EventTypeEnum -> CLRG, EventTypeEnum -> CLAL] any = cde.event.EventType
                and cde.execution.CentralCounterparty exists)
        then (reportableInformation -> sefOrDcmAnonymousIndicator default False)
        else (extract reportableInformation
        then extract
            if ((partyInformation
                    filter
                        regimeInformation -> supervisoryBody any = SupervisoryBodyEnum -> CFTC
                    then exists
                    )
                    and ([ExecutionVenueTypeEnum -> SEF, ExecutionVenueTypeEnum -> DCM] any = executionVenueType))
            then (sefOrDcmAnonymousIndicator default False))

reporting rule DTCC_SEFOrDCMIndicator from TransactionReportInstruction: <"SEF or DCM Indicator">
    filter cftcTrade.IsAllowableActionForCFTC
    then extract reportableInformation
    then extract
        if (executionVenueType = ExecutionVenueTypeEnum -> SEF
                or executionVenueType = ExecutionVenueTypeEnum -> DCM)
        then True
        else False

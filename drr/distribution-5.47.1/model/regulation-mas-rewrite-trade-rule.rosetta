reporting rule NotionalQuantityScheduleLeg1 from TransactionReportInstruction: <"Notional Quantity Schedule-Leg 1">
    [regulatoryReference MAS Trade dataElement "[Not in regulation]" field "Notional Quantity Schedules - Leg 1"
        provision "[Not in regulation] Notional Quantity Schedules - Leg 1"]

        as "[Not in regulation]-$ Notional quantity which becomes effective on the associated unadjusted effective date-Leg 1 (DTCC)"

reporting rule NotionalQuantityScheduleLeg1EffectiveDate from QuantityReportablePeriod: <"Notional quantity schedules - Unadjusted date on which the associated notional quantity becomes effective of leg 1">
    [regulatoryReference MAS Trade dataElement "[Not in regulation]" field "Notional quantity schedules - Unadjusted date on which the associated notional quantity becomes effective of leg 1"
        provision "Notional quantity schedules - Unadjusted date on which the associated notional quantity becomes effective of leg 1"]
    CDENotionalQuantityScheduleEffectiveDate
        as "[Not in regulation]-$ Notional quantity schedules - Unadjusted date on which the associated notional quantity becomes effective of leg 1 (DTCC)"

reporting rule NotionalQuantityScheduleLeg1EndDate from QuantityReportablePeriod: <"Notional quantity schedules - Unadjusted end date of the notional quantity of leg 1">
    [regulatoryReference MAS Trade dataElement "[Not in regulation]" field "Notional quantity schedules - Unadjusted end date of the notional quantity of leg 1"
        provision "Notional quantity schedules - Unadjusted end date of the notional quantity of leg 1"]
    CDENotionalQuantityScheduleEndDate
        as "[Not in regulation]-$ Notional quantity schedules - Unadjusted end date of the notional quantity of leg 1 (DTCC)"

reporting rule NotionalQuantityScheduleLeg2 from TransactionReportInstruction: <"Notional Quantity Schedule-Leg 2">
    [regulatoryReference MAS Trade dataElement "[Not in regulation]" field "Notional Quantity Schedules - Leg 2"
        provision "[Not in regulation] Notional Quantity Schedules - Leg 2"]
    filter IsAllowableAction
    then extract TradeForEvent
    then extract GetReportableQuantityPeriodLeg2
    then extract
        NotionalQuantityScheduleLeg2Report {
            value: NotionalQuantityScheduleLeg2Value,
            effectiveDate: NotionalQuantityScheduleLeg2EffectiveDate,
            endDate: NotionalQuantityScheduleLeg2EndDate
        }
    then sort [ item -> effectiveDate ]

reporting rule NotionalQuantityScheduleLeg2Value from QuantityReportablePeriod: <"Notional quantity schedules - Notional quantity which becomes effective on the associated unadjusted effective date-Leg 2">
    [regulatoryReference MAS Trade dataElement "[Not in regulation]" field "Notional quantity schedules - Notional quantity which becomes effective on the associated unadjusted effective date of leg 2"
        provision "Notional quantity schedules - Notional quantity which becomes effective on the associated unadjusted effective date of leg 2"]
    CDENotionalQuantityScheduleValue
        as "[Not in regulation]-$ Notional quantity which becomes effective on the associated unadjusted effective date-Leg 2 (DTCC)"

reporting rule NotionalQuantityScheduleLeg2EffectiveDate from QuantityReportablePeriod: <"Notional quantity schedules - Unadjusted date on which the associated notional quantity becomes effective of leg 2">
    [regulatoryReference MAS Trade dataElement "[Not in regulation]" field "Notional quantity schedules - Unadjusted date on which the associated notional quantity becomes effective of leg 2"
        provision "Notional quantity schedules - Unadjusted date on which the associated notional quantity becomes effective of leg 2"]
    CDENotionalQuantityScheduleEffectiveDate
        as "[Not in regulation]-$ Notional quantity schedules - Unadjusted date on which the associated notional quantity becomes effective of leg 2 (DTCC)"

reporting rule NotionalQuantityScheduleLeg2EndDate from QuantityReportablePeriod: <"Notional quantity schedules - Unadjusted end date of the notional quantity of leg 2">
    [regulatoryReference MAS Trade dataElement "[Not in regulation]" field "Notional quantity schedules - Unadjusted end date of the notional quantity of leg 2"
        provision "Notional quantity schedules - Unadjusted end date of the notional quantity of leg 2"]
    CDENotionalQuantityScheduleEndDate
        as "[Not in regulation]-$ Notional quantity schedules - Unadjusted end date of the notional quantity of leg 2 (DTCC)"

func IsAllowableActionForMAS:
    inputs:
        reportableEvent ReportableEvent (1..1)
    output:
        isAllowableAction boolean (1..1)

    set isAllowableAction:
        IsActionTypeNEWT(reportableEvent)
            or IsActionTypeMODI(reportableEvent)
            or IsActionTypePositionMODI(reportableEvent)
            or IsActionTypeCORR(reportableEvent)
            or IsActionTypeREVI(reportableEvent)
            or IsActionTypePOSC(reportableEvent)

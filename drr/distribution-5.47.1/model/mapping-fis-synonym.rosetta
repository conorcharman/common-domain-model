namespace cdm.mapping.fis
version "5.27.0"

import cdm.event.common.*
import cdm.event.workflow.*

synonym source FIS_BASE

synonym source FIS extends FIS_BASE
{
    WorkflowStep:
        + businessEvent
            [value "FIS_TRADE" mapper "FISMapper"]
        + lineage
            [value "ignore"]

    BusinessEvent:
        + instruction
            [value "ignore"]
        + after
            [value "ignore"]
}
